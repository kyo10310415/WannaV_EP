# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Discord Webhook for Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Admin Default Credentials
# メールアドレスではなくユーザー名で指定（初期PW は ADMIN_PASSWORD）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Upload Directory（Render Disk 使用時に設定）
# Render の Disk マウントパスに合わせて変更（例: /var/data/uploads）
# ローカル開発時は未設定のまま → ./uploads を使用
# UPLOAD_DIR=/var/data/uploads

# ===== Notion 連携（生徒一覧ページ）=====
# Notion Integration Token（https://www.notion.so/my-integrations で取得）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 対象データベースの ID（Notion DB ページの URL から取得）
# 例: https://www.notion.so/xxxxxxxx から xxxxxxxx 部分
NOTION_DATABASE_ID=88e474e5400f44998fa04d982b1c8ef7

